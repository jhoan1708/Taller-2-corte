✅ Código Arduino equivalente al laboratorio PIC
Este código está pensado para Arduino Uno, probado conceptualmente y listo para cargar.

```
// ==========================================================
// PIANO DIGITAL - ADAPTACIÓN DE PIC16F887 A ARDUINO UNO
// ==========================================================
// Este programa implementa un piano digital utilizando
// pulsadores y un speaker, replicando el comportamiento
// del laboratorio original desarrollado con el PIC16F887.
// ==========================================================


// ==========================================================
// 1. DEFINICIÓN DE PINES
// ==========================================================

// Pines de los pulsadores (teclas del piano)
const int teclaDO  = 2;
const int teclaRE  = 3;
const int teclaMI  = 4;
const int teclaFA  = 5;
const int teclaSOL = 6;
const int teclaLA  = 7;
const int teclaSI  = 8;

// Pin del speaker
const int speakerPin = 9;

// LED indicador (puede usarse el LED integrado)
const int ledPin = 13;


// ==========================================================
// 2. FRECUENCIAS DE LAS NOTAS (Hz)
// ==========================================================
// Estas frecuencias reemplazan los delays manuales del PIC
// y permiten una mejor generación de sonido usando tone().

const int freqDO  = 262;
const int freqRE  = 294;
const int freqMI  = 330;
const int freqFA  = 349;
const int freqSOL = 392;
const int freqLA  = 440;
const int freqSI  = 494;


// ==========================================================
// 3. CONFIGURACIÓN INICIAL
// ==========================================================

void setup() {

  // Configuramos entradas con resistencias pull-down externas
  pinMode(teclaDO,  INPUT);
  pinMode(teclaRE,  INPUT);
  pinMode(teclaMI,  INPUT);
  pinMode(teclaFA,  INPUT);
  pinMode(teclaSOL, INPUT);
  pinMode(teclaLA,  INPUT);
  pinMode(teclaSI,  INPUT);

  // Configuramos salidas
  pinMode(speakerPin, OUTPUT);
  pinMode(ledPin, OUTPUT);
}


// ==========================================================
// 4. BUCLE PRINCIPAL - LECTURA DE TECLAS Y SONIDO
// ==========================================================

void loop() {

  // DO
  if (digitalRead(teclaDO) == HIGH) {
    digitalWrite(ledPin, HIGH);
    tone(speakerPin, freqDO);
  }

  // RE
  else if (digitalRead(teclaRE) == HIGH) {
    digitalWrite(ledPin, HIGH);
    tone(speakerPin, freqRE);
  }

  // MI
  else if (digitalRead(teclaMI) == HIGH) {
    digitalWrite(ledPin, HIGH);
    tone(speakerPin, freqMI);
  }

  // FA
  else if (digitalRead(teclaFA) == HIGH) {
    digitalWrite(ledPin, HIGH);
    tone(speakerPin, freqFA);
  }

  // SOL
  else if (digitalRead(teclaSOL) == HIGH) {
    digitalWrite(ledPin, HIGH);
    tone(speakerPin, freqSOL);
  }

  // LA
  else if (digitalRead(teclaLA) == HIGH) {
    digitalWrite(ledPin, HIGH);
    tone(speakerPin, freqLA);
  }

  // SI
  else if (digitalRead(teclaSI) == HIGH) {
    digitalWrite(ledPin, HIGH);
    tone(speakerPin, freqSI);
  }

  // Si no hay ninguna tecla presionada
  else {
    noTone(speakerPin);
    digitalWrite(ledPin, LOW);
  }
}
```

